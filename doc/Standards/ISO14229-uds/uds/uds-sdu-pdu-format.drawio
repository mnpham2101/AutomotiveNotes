        <mxCell id="n9" parent="1" vertex="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#efe6fa;strokeColor=#6a3fa0;fontSize=9.5;align=center;verticalAlign=middle;" value="A_Length&#10;byte count of&#10;A_Data — 4 bytes&#10;M">
